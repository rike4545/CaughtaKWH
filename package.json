{
  "name": "caughtakwh",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "CaughtaKWH tracks Tesla Supercharger kWh pricing by station and recommends cheaper charging windows with 95% confidence intervals.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run sync:public && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "discover": "node scripts/discoverStations.mjs",
    "scrape": "node scripts/scrapePrices.mjs",
    "train:neural": "node scripts/trainPricingNeuralNetwork.mjs",
    "predict": "npm run train:neural && node scripts/buildPredictions.mjs",
    "test:neural": "node scripts/testPricingNeuralNetwork.mjs",
    "pilot:lake-grove": "node scripts/buildLakeGrovePilot.mjs",
    "update:data": "npm run discover && npm run scrape && npm run predict && npm run validate:data && npm run sync:public",
    "validate:data": "node scripts/validateData.mjs",
    "sync:public": "node scripts/syncPublicData.mjs",
    "improve:dashboard": "node scripts/dashboard-bot.mjs && npm run sync:public && npm run validate:data",
    "scrape:needs-history": "SCRAPE_NEEDS_HISTORY=true npm run scrape",
    "enrich:superchargeinfo": "node scripts/enrichFromSuperchargeInfo.mjs",
    "ingest:reports": "node scripts/ingestPriceReports.mjs",
    "social:post": "node scripts/socialBot.mjs",
    "social:summary": "node scripts/socialSummary.mjs",
    "agent:heal": "node scripts/selfHeal.mjs",
    "agent:drift": "node scripts/detectDrift.mjs",
    "agent:data": "node scripts/dataDoctor.mjs",
    "agent:improve": "node scripts/improveAgent.mjs",
    "agent:qa": "node scripts/predictionQA.mjs",
    "agent:community": "node scripts/communityQA.mjs",
    "community:rollup": "node scripts/communityRollup.mjs",
    "ingest:sheet": "node scripts/ingestSheet.mjs"
  },
  "dependencies": {
    "@playwright/test": "latest",
    "@vitejs/plugin-react": "latest",
    "leaflet": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "latest",
    "synaptic": "^1.1.4",
    "typescript": "latest",
    "undici": "^8.4.1",
    "vite": "latest"
  }
}
